# MongoDB (Abassi)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGODB_DB=stokos

# Stripe — platform account secret (Abassi)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Connect Express — Stokos connected account (Abassi)
STRIPE_CONNECT_ACCOUNT_ID=acct_xxx
STRIPE_PLATFORM_FEE_PERCENT=1.5

# App
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Clerk — admin auth (Azan)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# Admin allowlist — comma-separated staff emails (Azan)
ADMIN_EMAILS=admin@example.com
